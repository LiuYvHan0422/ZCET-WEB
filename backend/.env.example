# App
NODE_ENV=development
PORT=8001
API_PREFIX=api/v1

# CORS (comma-separated)
CORS_ORIGIN=http://localhost:5173,http://localhost:8010

# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=
DB_DATABASE=webv1
DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=false
DB_LOGGING=true

# JWT (required)
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRATION=7d

# Dev-only helpers
ENABLE_DEV_LOGIN=false
DEV_LOGIN_USERNAME=admin
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=

# OSS upload
OSS_REGION=oss-cn-hangzhou
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_CDN_BASE_URL=
OSS_OBJECT_PREFIX=uploads
OSS_MAX_FILE_SIZE=5242880

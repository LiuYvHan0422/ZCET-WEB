# Cloudflare API authentication
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# Pages project names
CF_FRONTEND_PROJECT=webv1-frontend
CF_FRONTEND_BRANCH=main
CF_ADMIN_PROJECT=webv1-admin
CF_ADMIN_BRANCH=main

# Worker/Containers name
CF_API_WORKER_NAME=webv1-api
# Backend deploy mode: worker (no Docker) or container (requires Docker)
CF_BACKEND_MODE=worker
# Optional custom domain for backend API, e.g. api.example.com
CF_API_DOMAIN=

# Build-time API base URLs
PUBLIC_API_BASE=https://webv1-api.<your-subdomain>.workers.dev/api/v1
ADMIN_API_BASE=https://webv1-api.<your-subdomain>.workers.dev/api/v1

# Backend runtime env
API_PREFIX=api/v1
CORS_ORIGIN=https://www.example.com,https://admin.example.com

DB_HOST=
DB_PORT=3306
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=

DB_SYNCHRONIZE=false
DB_MIGRATIONS_RUN=false
DB_LOGGING=false

JWT_SECRET=
JWT_EXPIRATION=7d

ENABLE_DEV_LOGIN=false
DEV_LOGIN_USERNAME=admin
SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=
